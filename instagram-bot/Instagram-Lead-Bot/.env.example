# ══════════════════════════════════════════════════════════════════
#  Instagram Lead Bot — ملف إعدادات البيئة
#
#  التعليمات:
#    1. انسخ هذا الملف: cp .env.example .env
#    2. عدّل القيم بياناتك الحقيقية
#    3. لا ترفع ملف .env على GitHub أبداً!
# ══════════════════════════════════════════════════════════════════

# ── بيانات Instagram ──
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# ── إعدادات السيرفر ──
PORT=8081
DEBUG_MODE=false

# ── حدود العمليات اليومية ──
# MAX_DM_PER_DAY=20
# MAX_FOLLOWS_PER_DAY=30

# ── Playwright ──
PLAYWRIGHT_BROWSERS_PATH=/home/botuser/.playwright

# ── Streamlit ──
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
